    <recordUpdates>
        <name>Atribui_maior_que_400</name>
        <label>Atribui maior que 400</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Atualiza_Taxa_efetiva</targetReference>
        </connector>
        <inputAssignments>
            <field>Comiss_o__c</field>
            <value>
                <elementReference>Acima_400_Ton</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Atualiza_Comiss_o_Servi_os</name>
        <label>Atualiza Comissão - Serviços</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Atualiza_Taxa_efetiva</targetReference>
        </connector>
        <inputAssignments>
            <field>Comiss_o__c</field>
            <value>
                <elementReference>Comissao_Gal</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Atualiza_Taxa_efetiva</name>
        <label>Atualiza Taxa efetiva</label>
