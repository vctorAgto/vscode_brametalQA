    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Verifica_usu_rio_representante</targetReference>
        </connector>
        <filterLogic>(1 OR 2) and 3</filterLogic>
        <filters>
            <field>Setor_de_atividade__c</field>
            <operator>StartsWith</operator>
            <value>
                <stringValue>Poste</stringValue>
            </value>
        </filters>
        <filters>
            <field>Unidade_de_Negocio__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Servicos</stringValue>
            </value>
        </filters>
        <filters>
            <field>Mercado__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Interno</stringValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
