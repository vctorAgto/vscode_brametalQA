    <recordUpdates>
        <name>Limpa_campos</name>
        <label>Limpa campos</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Comiss_o__c</field>
        </inputAssignments>
        <inputAssignments>
            <field>taxa_efetiva_comissao__c</field>
